import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LogisticRegression
import joblib

# Load dataset
df = pd.read_csv("dataset.csv")

# Encode categorical
df["College_Tier"] = df["College_Tier"].astype("category").cat.codes
df["Program_Type"] = df["Program_Type"].astype("category").cat.codes

# Features & target
X = df[["Final_Price", "Discount_%", "Family_Income", "College_Tier", "Program_Type"]]
y = df["Converted"]

# Train model
model = LogisticRegression(max_iter=1000)
model.fit(X, y)

# Save model (IMPORTANT)
joblib.dump(model, "model.pkl")
